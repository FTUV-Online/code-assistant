{
  "name": "dev-code",
  "displayName": "dev-code",
  "description": "Open-source code completion. Use any provider compatible with Anthropic, OpenAI, Gemini, or Ollama.",
  "version": "0.6.2",
  "publisher": "dev-code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FTUV-Online/code-assistant.git"
  },
  "engines": {
    "vscode": "^1.122.1"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "code completion",
    "copilot",
    "claude",
    "anthropic",
    "openai",
    "ollama",
    "gemini",
    "llm"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devCodeContainer",
          "title": "dev-code Tool",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "devCodeContainer": [
        {
          "type": "webview",
          "id": "devCode.mainView",
          "name": ""
        }
      ]
    },
    "configuration": {
      "title": "dev-code",
      "properties": {
        "devCode.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable inline completion."
        },
        "devCode.activeProvider": {
          "type": "string",
          "default": "",
          "description": "ID of the provider currently in use."
        },
        "devCode.providers": {
          "type": "array",
          "default": [],
          "description": "List of configured providers. Use the \"dev-code: Setup Provider\" command for an easier setup.",
          "items": {
            "type": "object",
            "required": [
              "id",
              "protocol",
              "baseURL",
              "model"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Internal ID used to switch between providers."
              },
              "displayName": {
                "type": "string",
                "description": "Friendly name shown in the UI (optional)."
              },
              "protocol": {
                "type": "string",
                "enum": [
                  "anthropic",
                  "openai",
                  "gemini",
                  "ollama"
                ],
                "description": "API protocol. anthropic = /v1/messages, openai = /v1/chat/completions."
              },
              "baseURL": {
                "type": "string",
                "description": "API endpoint (e.g. https://api.anthropic.com)."
              },
              "model": {
                "type": "string",
                "description": "Model name (e.g. claude-haiku-4-5)."
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom HTTP headers (e.g. Azure api-version, proxy auth)."
              },
              "authScheme": {
                "type": "string",
                "enum": [
                  "x-api-key",
                  "bearer",
                  "custom-header"
                ],
                "description": "How the API Key (stored in SecretStorage) is sent. Defaults to x-api-key for anthropic, bearer for openai."
              },
              "authHeaderName": {
                "type": "string",
                "description": "When authScheme = custom-header: the header name receiving the API Key."
              },
              "authValuePrefix": {
                "type": "string",
                "description": "Optional prefix added before the API Key value (e.g. \"Bearer \", \"Token \")."
              },
              "maxTokens": {
                "type": "number",
                "default": 256
              },
              "temperature": {
                "type": "number",
                "default": 0.2
              },
              "supportsFIM": {
                "type": "boolean",
                "default": false
              },
              "promptCaching": {
                "type": "boolean",
                "default": false,
                "description": "Enable prompt caching (Anthropic only)."
              },
              "contextLimitTokens": {
                "type": "number",
                "minimum": 1,
                "description": "Approximate context window limit for this provider, in tokens. Used for UI context budgeting and auto-compaction planning."
              }
            }
          }
        },
        "devCode.context": {
          "type": "object",
          "default": {
            "autoCompact": true,
            "compactThresholdPercent": 80,
            "reserveOutputTokens": 2048
          },
          "description": "Global context budgeting settings for chat sessions.",
          "properties": {
            "autoCompact": {
              "type": "boolean",
              "description": "Enable automatic context compaction when sessions approach the configured limit."
            },
            "compactThresholdPercent": {
              "type": "number",
              "minimum": 1,
              "maximum": 100,
              "description": "Percentage of the context window at which compaction should begin."
            },
            "reserveOutputTokens": {
              "type": "number",
              "minimum": 0,
              "description": "Tokens reserved for the next assistant response so the session leaves headroom before compaction."
            }
          }
        },
        "devCode.debounceMs": {
          "type": "number",
          "default": 400,
          "description": "Delay after the user stops typing before calling the LLM (ms)."
        },
        "devCode.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show ✨ Explain / ✨ Review code lenses above functions and classes."
        },
        "devCode.features": {
          "type": "object",
          "default": {
            "completion": {
              "enabled": true,
              "providerId": ""
            },
            "explain": {
              "enabled": true,
              "providerId": ""
            },
            "review": {
              "enabled": true,
              "providerId": ""
            },
            "rewrite": {
              "enabled": true,
              "providerId": ""
            },
            "commitMessage": {
              "enabled": true,
              "providerId": ""
            },
            "prDescription": {
              "enabled": true,
              "providerId": ""
            },
            "branchName": {
              "enabled": true,
              "providerId": ""
            }
          },
          "description": "Per-feature enable flag and override provider ID. Empty providerId = use the active provider.",
          "properties": {
            "completion": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            },
            "explain": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            },
            "review": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            },
            "rewrite": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            },
            "commitMessage": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            },
            "prDescription": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            },
            "branchName": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "providerId": {
                  "type": "string"
                }
              }
            }
          }
        },
        "devCode.contextLines": {
          "type": "object",
          "default": {
            "before": 50,
            "after": 20
          },
          "description": "Number of code lines to include in context before/after the cursor.",
          "properties": {
            "before": {
              "type": "number"
            },
            "after": {
              "type": "number"
            }
          }
        },
        "devCode.toolUse.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Let AI Explain/Review call workspace tools (read_file, grep, list_dir, find_files) to gather extra context. Disable for faster but less accurate responses."
        },
        "devCode.toolUse.maxIterations": {
          "type": "number",
          "default": 64,
          "minimum": 1,
          "maximum": 255,
          "description": "Maximum tool-use round-trips per chat turn before stopping."
        },
        "devCode.toolUse.allowWriteTools": {
          "type": "boolean",
          "default": true,
          "description": "Allow the AI to use write_file and edit_file. Each call still asks for user approval. Default on."
        },
        "devCode.toolUse.showDiffPreview": {
          "type": "boolean",
          "default": true,
          "description": "Open a side-by-side diff editor before approving write_file / edit_file calls so you can review the exact change. Disable to fall back to a text-only summary."
        },
        "devCode.toolUse.editFileAutoRetry": {
          "type": "boolean",
          "default": false,
          "description": "When edit_file fails because its find strings no longer match the file, automatically re-read the latest file content and give the AI one retry. Default off."
        },
        "devCode.toolUse.allowShell": {
          "type": "boolean",
          "default": true,
          "description": "Allow the AI to run shell commands via the run_command tool (PowerShell on Windows, sh on Linux/Mac). Each call asks for user approval unless the command matches shellAutoApprove. Default on."
        },
        "devCode.toolUse.shellAutoApprove": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Command prefixes that auto-approve without prompting. Example: [\"npm\", \"git status\", \"dotnet test\"]. Commands containing shell operators (&, |, ;, >, $(, etc.) are NEVER auto-approved regardless of this list."
        },
        "devCode.toolUse.shellTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Default timeout in milliseconds for run_command. Caller can override per-call up to 300000 (5 min)."
        },
        "devCode.mcp.servers": {
          "type": "object",
          "default": {},
          "description": "MCP (Model Context Protocol) servers. Key is server name. Transport can be 'stdio' (local subprocess, default), 'streamable-http' (remote HTTP+SSE), or 'websocket' (remote WebSocket).",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "transport": {
                "type": "string",
                "enum": [
                  "stdio",
                  "streamable-http",
                  "websocket"
                ],
                "description": "Transport type. Defaults to 'stdio' if omitted (backward compatible)."
              },
              "command": {
                "type": "string",
                "description": "Executable to launch (stdio transport)."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Arguments passed to the command (stdio transport)."
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Extra environment variables for the server process (stdio transport)."
              },
              "url": {
                "type": "string",
                "description": "Server URL (streamable-http or websocket transport)."
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Custom HTTP headers sent with every request (streamable-http transport)."
              }
            }
          }
        },
        "devCode.mcp.disabledTools": {
          "type": "object",
          "default": {},
          "description": "Disabled MCP tools per server. Key is server name, value is array of tool names to hide from the AI.",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "devCode.toolUse.blacklist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".env",
            ".env.*",
            "*.pem",
            "*.key",
            "*_rsa",
            "*_dsa",
            "*_ecdsa",
            "*_ed25519",
            "**/secrets/**",
            "**/.ssh/**",
            ".aws/credentials",
            ".kube/config"
          ],
          "description": "Glob patterns that tool calls (read_file, grep, find_files) refuse to read. Prevents AI from accessing secrets."
        },
        "devCode.includeFullFileInAnalysis": {
          "type": "boolean",
          "default": true,
          "description": "Send the full file content together with the diff for AI Explain/Review. More accurate but uses more tokens."
        },
        "devCode.outputLanguage": {
          "type": "string",
          "default": "English",
          "enum": [
            "English",
            "Vietnamese",
            "Chinese (Simplified)",
            "Chinese (Traditional)",
            "Japanese",
            "Korean",
            "French",
            "German",
            "Spanish",
            "Portuguese",
            "Russian"
          ],
          "description": "Language used for AI Explain change and Review change. Commit messages always stay in English."
        }
      }
    },
    "commands": [
      {
        "command": "devCode.setupProvider",
        "title": "dev-code: Setup Provider"
      },
      {
        "command": "devCode.switchProvider",
        "title": "dev-code: Switch Active Provider"
      },
      {
        "command": "devCode.toggleEnabled",
        "title": "dev-code: Toggle Enable/Disable"
      },
      {
        "command": "devCode.removeApiKey",
        "title": "dev-code: Remove API Key"
      },
      {
        "command": "devCode.showLogs",
        "title": "dev-code: Show Logs"
      },
      {
        "command": "devCode.explainCode",
        "title": "Explain selection",
        "category": "dev-code"
      },
      {
        "command": "devCode.reviewCode",
        "title": "Review selection",
        "category": "dev-code"
      },
      {
        "command": "devCode.rewriteCode",
        "title": "Rewrite (optimize) selection",
        "category": "dev-code"
      },
      {
        "command": "devCode.inlineEdit",
        "title": "Inline edit selection (Cmd+K)",
        "category": "dev-code"
      }
    ],
    "keybindings": [
      {
        "command": "devCode.inlineEdit",
        "key": "ctrl+k ctrl+i",
        "mac": "cmd+k cmd+i",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "submenus": [
      {
        "id": "devCode.editorContext",
        "label": "dev-code Tool"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "devCode.editorContext",
          "group": "1_dev-code@1",
          "when": "editorHasSelection"
        }
      ],
      "devCode.editorContext": [
        {
          "command": "devCode.explainCode",
          "group": "1@1"
        },
        {
          "command": "devCode.reviewCode",
          "group": "1@2"
        },
        {
          "command": "devCode.rewriteCode",
          "group": "1@3"
        },
        {
          "command": "devCode.inlineEdit",
          "group": "1@4"
        }
      ]
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ./",
    "compile": "npm run typecheck && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "tsx --test test/**/*.test.ts",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
